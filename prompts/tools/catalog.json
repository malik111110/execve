{
  "version": 1,
  "tools": [
    {
      "name": "read_file",
      "description": "Read file content with line range and byte limits.",
      "arguments": {
        "path": "string, required",
        "start_line": "integer, optional, default 1",
        "end_line": "integer, optional",
        "max_bytes": "integer, optional"
      }
    },
    {
      "name": "search_code",
      "description": "Search source files with query and optional include glob.",
      "arguments": {
        "query": "string, required",
        "max_results": "integer, optional",
        "include_glob": "string, optional"
      }
    },
    {
      "name": "git_diff",
      "description": "Return workspace git diff (staged or unstaged).",
      "arguments": {
        "staged": "boolean, optional",
        "path": "string, optional",
        "max_bytes": "integer, optional"
      }
    },
    {
      "name": "create_file",
      "description": "Create a new file (or overwrite when explicitly allowed).",
      "arguments": {
        "path": "string, required",
        "content": "string, optional",
        "overwrite": "boolean, optional, default false",
        "dry_run": "boolean, optional",
        "create_dirs": "boolean, optional, default true"
      }
    },
    {
      "name": "execute_command",
      "description": "Execute or continue shell commands with terminal pooling, line streaming, and permission policy controls.",
      "arguments": {
        "command": "string, required unless continue=true or stop=true",
        "terminal_id": "string, optional",
        "terminal_name": "string, optional",
        "continue": "boolean, optional",
        "stop": "boolean, optional",
        "line_offset": "integer, optional",
        "max_line_events": "integer, optional",
        "wait_for_completion": "boolean, optional",
        "wait_ms": "integer, optional",
        "stream_lines": "boolean, optional",
        "reuse_terminal": "boolean, optional",
        "permission_mode": "string, optional: defaultApproval|bypassApproval|autopilot",
        "permission_policy": "object, optional: allowed_commands|blocked_commands|allowed_mcps|blocked_mcps",
        "dry_run": "boolean, optional",
        "timeout_ms": "integer, optional",
        "max_output_bytes": "integer, optional"
      }
    },
    {
      "name": "ask_follow_up_question",
      "description": "Generate focused clarification questions when a prompt is too ambiguous for an actionable plan.",
      "arguments": {
        "prompt": "string, required",
        "selected_text": "string, optional",
        "active_file_path": "string, optional",
        "max_questions": "integer, optional, default 3"
      }
    }
  ]
}
